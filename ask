import sys
import json
import urllib.request
import os

if len(sys.argv) < 2:
    print("Usage: python3 ai_assistant.py \"your request here\"")
    sys.exit(1)

API_KEY = os.environ.get("GEMINI_API_KEY")
if not API_KEY:
    print("Error: GEMINI_API_KEY environment variable not set.")
    sys.exit(1)

URL = f"https://generativelanguage.googleapis.com/v1beta/models/gemini-3.5-flash:generateContent?key={API_KEY}"


instruction = (
    "You are a strict Linux terminal expert. Translate the user's request "
    "into a valid, single-line Linux bash command. Return ONLY the raw command. "
    "Do not include code blocks, markdown text, explanations, or backticks.\n\n"
    "User Request: "
)
full_prompt = instruction + sys.argv[1]

payload = {
    "contents": [
        {"parts": [{"text": full_prompt}]}
    ]
}

req = urllib.request.Request(
    URL, 
    data=json.dumps(payload).encode("utf-8"), 
    headers={"Content-Type": "application/json"}
)

try:
    with urllib.request.urlopen(req) as response:
        result = json.loads(response.read().decode("utf-8"))
        command = result["candidates"][0]["content"]["parts"][0]["text"].strip()
        print(f"\n Suggested Command:\n{command}\n")
        
except Exception as e:
    print(f"\n Connection Error: {e}")
    if hasattr(e, 'read'):
        print(e.read().decode('utf-8'))
